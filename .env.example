# ════════════════════════════════════════════════════════════════
# ATHIDHI RESTAURANT & ROS — ENVIRONMENT CONFIGURATION TEMPLATE
# ════════════════════════════════════════════════════════════════
# Copy this file to `.env.local` for local development.
# For Vercel production deployment, add these variables in your Vercel Dashboard:
# Settings -> Environment Variables

# ────────── Supabase Configuration ──────────
# Project URL (from Supabase Dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / Public Key (from Supabase Dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service Role Secret (Optional: needed for admin server tasks)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ────────── Application Base URLs ──────────
# Public Customer Website URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Restaurant Operating System (ROS) Admin URL
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# ────────── Application Surface Scoping ──────────
# Use "customer" for the main website, or "admin" for dedicated admin panel Vercel deployment
APP_SURFACE=customer
